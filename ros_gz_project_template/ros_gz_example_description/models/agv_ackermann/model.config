<?xml version="1.0"?>
<!--
  agv_ackermann model config
  Port AGV based on Volvo FH16 proportions, rebuilt for Ignition Fortress.
  Visual geometry uses box/cylinder primitives matching volvofh16 dimensions.
  NO trailer — tractor unit only for port AGV application.
-->
<model>
  <name>agv_ackermann</name>
  <version>1.0</version>
  <sdf version="1.8">model.sdf</sdf>

  <author>
    <name>AGV Digital Twin Project</name>
  </author>

  <description>
    Port AGV truck (Ackermann steering) based on Volvo FH16 proportions.
    Uses AckermannSteering plugin for Ignition Fortress (Gazebo 6).
    Tractor unit only, no trailer.
  </description>
</model>
